# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored. Build with: flutter run --dart-define-from-file=.env
# (also works for `flutter build`).

# Google Maps web-service key (Places Autocomplete, Place Details, Geocoding).
# Restrict this key by API + HTTP referrer/IP in the Google Cloud Console.
GOOGLE_MAPS_API_KEY=your_google_maps_web_service_key_here
