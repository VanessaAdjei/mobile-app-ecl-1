<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production API — system CAs only (no user-installed MITM certs). -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">ernestchemists.com.gh</domain>
        <domain includeSubdomains="true">eclcommerce.ernestchemists.com.gh</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Local test host (ExpressPay redirect) — HTTP only for dev -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">eclcommerce.test</domain>
    </domain-config>
    
    <!-- Default configuration for all other domains -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
